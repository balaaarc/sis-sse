{
  "name": "iinvsys-sse",
  "version": "1.0.0",
  "description": "IINVSYS SIS Sensor Simulation Engine - generates synthetic sensor data for the surveillance dashboard",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop iinvsys-sse",
    "pm2:restart": "pm2 restart iinvsys-sse",
    "pm2:logs": "pm2 logs iinvsys-sse",
    "test:backend": "echo 'No backend tests yet' && exit 0"
  },
  "dependencies": {
    "@faker-js/faker": "^8.4.1",
    "@fastify/cors": "^9.0.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "fastify": "^4.28.1",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "sharp": "^0.33.4",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.17",
    "@types/sharp": "^0.31.1",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "pm2": "^5.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
